rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Common Helpers
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidRSVP(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && (!data.keys().hasAll(['email']) || data.email == null || (data.email is string && data.email.size() <= 100))
        && data.attending is bool
        && data.guestsCount is int && data.guestsCount >= 1 && data.guestsCount <= 20
        && (!data.keys().hasAll(['dietary']) || data.dietary == null || (data.dietary is string && data.dietary.size() <= 1000))
        && (!data.keys().hasAll(['message']) || data.message == null || (data.message is string && data.message.size() <= 1000))
        && data.createdAt is timestamp;
    }

    function isValidGuestPhoto(data) {
      return data.uploaderName is string && data.uploaderName.size() > 0 && data.uploaderName.size() <= 100
        && data.imageUri is string && data.imageUri.size() > 0 && data.imageUri.size() <= 5000000
        && (!data.keys().hasAll(['caption']) || data.caption == null || (data.caption is string && data.caption.size() <= 500))
        && data.likes is int && data.likes >= 0
        && data.createdAt is timestamp;
    }

    // Collection rsvps
    match /rsvps/{rsvpId} {
      allow create: if isValidId(rsvpId) && isValidRSVP(incoming()) && incoming().createdAt == request.time;
      allow read: if true;
    }

    // Collection guestPhotos
    match /guestPhotos/{photoId} {
      allow create: if isValidId(photoId) && isValidGuestPhoto(incoming()) && incoming().createdAt == request.time && incoming().likes == 0;
      allow read, list: if true;
      allow update: if isValidId(photoId) 
        && isValidGuestPhoto(incoming()) 
        && incoming().createdAt == existing().createdAt 
        && incoming().diff(existing()).affectedKeys().hasOnly(['likes']) 
        && incoming().likes == existing().likes + 1;
    }
  }
}
